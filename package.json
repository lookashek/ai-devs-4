{
  "name": "ai-devs-4",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "general",
    "backend",
    "frontend",
    "lessons/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "build": "npm run build --workspace=frontend",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
